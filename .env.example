# Local Development Environment

## DynamoDB
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE=design-studio-local

## Auth & Tokens
JWT_SECRET=dev-secret-key-for-testing-only-never-use-in-production
JWT_EXPIRY=7d

## Bedrock (optional - only needed if testing agent integration)
AWS_BEDROCK_REGION=eu-north-1
# AWS_BEDROCK_ACCESS_KEY_ID=<your-real-aws-key-for-bedrock>
# AWS_BEDROCK_SECRET_ACCESS_KEY=<your-real-aws-secret-for-bedrock>
BEDROCK_MODEL_ID=claude-sonnet-4-20250514

## GitHub OAuth (for authentication, not required for local development)
# GITHUB_OAUTH_CLIENT_ID=<from-github-app>
# GITHUB_OAUTH_SECRET=<from-github-app>
# GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

## Figma (optional - for design importer integration)
# FIGMA_TOKEN_ARN=arn:aws:secretsmanager:us-east-1:...

## GitHub App (optional - for PR creation)
# GITHUB_APP_ID=<app-id>
# GITHUB_APP_PRIVATE_KEY=<private-key>
# GITHUB_APP_WEBHOOK_SECRET=<webhook-secret>

## API Configuration
API_URL=http://localhost:3001
API_PORT=3001
NODE_ENV=development

## Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME="Design Studio"
